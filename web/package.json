{
  "name": "issueflow-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "overrides": {
    "esbuild": "0.25.0",
    "glob": "10.5.0",
    "vite": "8.1.2"
  },
  "scripts": {
    "dev": "vite",
    "dev:mock": "vite --mode mock",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run"
  },
  "dependencies": {
    "@vueuse/core": "^13.7.0",
    "a2ui-vue": "^0.9.3",
    "naive-ui": "^2.42.0",
    "pinia": "^3.0.3",
    "vue": "^3.5.39",
    "vue-i18n": "^11.4.6",
    "vue-router": "^4.6.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.29.0",
    "@types/node": "^24.0.4",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^9.29.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.2.0",
    "globals": "^16.2.0",
    "jsdom": "^26.1.0",
    "msw": "^2.14.6",
    "prettier": "^3.6.2",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.34.1",
    "vite": "8.1.2",
    "vitest": "^3.2.3",
    "vue-tsc": "^3.0.1"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
